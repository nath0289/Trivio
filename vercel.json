{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/notify?type=revenue",         "schedule": "0 5 1 * *"  },
    { "path": "/api/notify?type=expenses-noon",   "schedule": "0 10 * * *" },
    { "path": "/api/notify?type=expenses-evening","schedule": "0 18 * * *" },
    { "path": "/api/notify?type=interest",        "schedule": "0 5 * * *"  }
  ]
}
